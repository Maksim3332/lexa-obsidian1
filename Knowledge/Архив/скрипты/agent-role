def get_current_role():
    role_file = "/tmp/agent-current-role"
    if os.path.exists(role_file):
        with open(role_file) as f:
            return f.read().strip()
    return "general"


def set_current_role(role):
    role_file = "/tmp/agent-current-role"
    with open(role_file, "w") as f:
        f.write(role)
    # Record in graph memory
    config = ROLES[role]
    subprocess.run([
        "graph-memory", "add",
        f"Role switch → {config['name']} at {datetime.now().isoformat()}",
        "--type", "behavioral", "--scope", "project",
        "--significance", "0.3", "--intensity", "0.1",
    ], capture_output=True)


def cmd_list(args=None):
    print(f"{'ROLE':<15} {'NAME':<20} {'DESCRIPTION'}")
    print("-" * 70)
    for rid, rconfig in ROLES.items():
        marker = "*" if rid == get_current_role() else " "
        print(f"{marker} {rid:<13} {rconfig['name']:<20} {rconfig['description']}")


def cmd_current(args=None):
    role = get_current_role()
    config = ROLES[role]
    print(f"Current role: {config['name']} ({role})")
    print(f"Description: {config['description']}")
    if config["allowed_tools"]:
        print(f"Allowed tools: {', '.join(config['allowed_tools'])}")
    else:
        print("Allowed tools: ALL")
    print(f"Traits: {', '.join(config['traits'])}")


def cmd_switch(args):
    role = args.role
    if role not in ROLES:
        print(f"Unknown role: {role}")
        print(f"Available: {', '.join(ROLES.keys())}")
        sys.exit(1)

    old_role = get_current_role()
    if old_role == role:
        print(f"Already on role: {ROLES[role]['name']}")
        return

    set_current_role(role)
    config = ROLES[role]
    print(f"Switched: {ROLES[old_role]['name']} → {config['name']}")
    print(f"Description: {config['description']}")

    if config["allowed_tools"]:
        print(f"Allowed tools: {', '.join(config['allowed_tools'])}")

    # Print system prompt preamble for agent to use
    print(f"\n{'─' * 50}")
    print(f"SYSTEM PROMPT PREAMBLE:")
    print(f"{'─' * 50}")
    print(config["system_prompt_preamble"])


def cmd_describe(args):
    role = args.role
    if role not in ROLES:
        print(f"Unknown role: {role}")
        sys.exit(1)
    config = ROLES[role]
    out = {
        "role": role,
        "name": config["name"],
        "description": config["description"],
        "allowed_tools": config["allowed_tools"],
        "skill_ids": config["skill_ids"],
        "system_prompt_preamble": config["system_prompt_preamble"],
        "traits": config["traits"],
    }
    print(json.dumps(out, indent=2))


def main():
    parser = argparse.ArgumentParser(description="SubAgent Role Switcher")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("list")
    sub.add_parser("current")

    p_switch = sub.add_parser("switch")
    p_switch.add_argument("role", choices=list(ROLES.keys()))

    p_desc = sub.add_parser("describe")
    p_desc.add_argument("role", choices=list(ROLES.keys()))

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return

    {
        "list": cmd_list,
        "current": cmd_current,
        "switch": cmd_switch,
        "describe": cmd_describe,
    }[args.command](args)


if __name__ == "__main__":
    main()
